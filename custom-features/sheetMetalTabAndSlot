const EDGE_LENGTH_TOLERANCE = 1e-9 * meter;
const EDGE_PARAMETER_TOLERANCE = 1e-6;
const FRACTION_TOLERANCE = 1e-9;

export const SPACING_BOUNDS =
{
            (inch) : [1e-6, 6, 1e6]
        } as LengthBoundSpec;

export const TAB_WIDTH_BOUNDS =
{
            (inch) : [1e-6, 1, 1e6]
        } as LengthBoundSpec;

export const TAB_DEPTH_BOUNDS =
{
            (inch) : [1e-6, .05, 1e6]
        } as LengthBoundSpec;

export const SLOT_MARGIN_BOUNDS =
{
            (inch) : [0, .01, 1e6]
        } as LengthBoundSpec;
export const CHAMFER_WIDTH_BOUNDS =
{
            (inch) : [0, .02, 1]
        } as LengthBoundSpec;

export enum SpacingType
{
    annotation { "Name" : "Equal" }
    EQUAL,
    annotation { "Name" : "Length" }
    LENGTH
}

annotation { "Feature Type Name" : "OnlyTabs - Boss Display", "Feature Type Description" : "Tab and Slot feature for Boss Display", "Icon" : ICON::BLOB_DATA }
export const tabAndSlotBossDisplay = defineFeature(function(context is Context, id is Id, definition is map)
    precondition
    {
        // Define the parameters of the feature type
        annotation { "Name" : "Edges", "Filter" : EntityType.EDGE, "UIHint" : UIHint.SHOW_CREATE_SELECTION }
        definition.edges is Query;

        annotation { "Name" : "Spacing Type" }
        definition.spacingType is SpacingType;

        if (definition.spacingType == SpacingType.LENGTH)
        {
            annotation { "Name" : "Spacing" }
            isLength(definition.spacing, SPACING_BOUNDS);
        }

        if (definition.spacingType == SpacingType.EQUAL)
        {
            annotation { "Name" : "Tab Count" }
            isInteger(definition.tabCount, POSITIVE_COUNT_BOUNDS);
        }



        annotation { "Name" : "Tab Width" }
        isLength(definition.tabWidth, TAB_WIDTH_BOUNDS);

        annotation { "Name" : "Tab Depth" }
        isLength(definition.tabDepth, TAB_DEPTH_BOUNDS);

        annotation { "Name" : "Tab Chamfer Width" }
        isLength(definition.tabChamfer, CHAMFER_WIDTH_BOUNDS);

        annotation { "Name" : "Slot Width Margin" }
        isLength(definition.slotMargin, SLOT_MARGIN_BOUNDS);

        annotation { "Name" : "Merge Scope", "Filter" : EntityType.BODY }
        definition.mergeScope is Query;

        annotation { "Name" : "Remove Rip Joints" }
        definition.removeRipJoints is boolean;

    }
    {
        // Phase 1: Split the input edges using the edge splitting method
        const selectedEdgesQuery = qEntityFilter(definition.edges, EntityType.EDGE);
        const selectedEdges = evaluateQuery(context, selectedEdgesQuery);
        if (size(selectedEdges) == 0)
        {
            throw regenError("Select at least one sheet metal edge", ["edges"]);
        }

        const orderedEdgeQuery = qUnion(selectedEdges);
        const path = try silent(constructPath(context, orderedEdgeQuery));
        if (path == undefined)
        {
            throw regenError("Unable to order the selected edges into a continuous chain", ["edges"], definition.edges);
        }

        // Calculate tab positions along the edge chain (as normalized parameters from 0 to 1)
        const totalLength = evLength(context, {
                "entities" : definition.edges
            });
        
        var tabCount = 0;
        var tabDomains = [];  // Array of {start, end} maps representing tab positions as normalized parameters
        
        if (definition.spacingType == SpacingType.EQUAL)
        {
            tabCount = definition.tabCount;
            tabDomains = calculateEqualSpacedTabDomains(totalLength, definition.tabWidth, tabCount);
        }
        else if (definition.spacingType == SpacingType.LENGTH)
        {
            tabCount = floor((totalLength - definition.tabWidth) / definition.spacing);
            tabDomains = calculateLengthSpacedTabDomains(totalLength, definition.tabWidth, definition.spacing, tabCount);
        }
        
        if (tabCount == 0 || size(tabDomains) == 0)
        {
            throw regenError("No tabs can fit with the specified parameters", ["tabWidth", "spacing"]);
        }

        // Track original edges before splitting
        const trackedEdges = startTracking(context, orderedEdgeQuery);

        // Split the edges at tab boundaries
        const splitParameters = calculateSplitParametersFromTabDomains(tabDomains);
        const splitInstructions = calculateEdgeSplitInstructionsFromParameters(context, path, splitParameters);
        
        if (size(splitInstructions) == 0)
        {
            throw regenError("Unable to calculate edge split locations", ["edges"]);
        }

        var splitOperationIndex = 0;
        for (var instruction in splitInstructions)
        {
            try
            {
                @opSplitEdges(context, id + ("split" ~ toString(splitOperationIndex)), {
                            "edges" : instruction.edge,
                            "parameters" : [instruction.parameters]
                        });
            }
            catch
            {
                throw regenError("Failed to split the sheet metal edge chain at the requested locations", ["edges"], instruction.edge);
            }
            splitOperationIndex += 1;
        }

        // Get the split edges
        const splitEdges = qEntityFilter(trackedEdges, EntityType.EDGE);
        const tabSegmentEdges = identifyTabSegmentEdgesFromDomains(context, splitEdges, path, totalLength, tabDomains);
        
        // Debug: Highlight tab segment edges to verify identification
        debug(context, tabSegmentEdges, DebugColor.YELLOW);

        // Phase 2: Copy adjacent sheet metal wall surfaces
        const adjacentFaces = qAdjacent(splitEdges, AdjacencyType.EDGE, EntityType.FACE);
        const wallFaces = filterSheetMetalWallFaces(context, adjacentFaces);
        
        if (size(evaluateQuery(context, wallFaces)) == 0)
        {
            throw regenError("No adjacent wall surfaces found to copy", ["edges"]);
        }

        // Phase 3: Track tab segment edges directly through extraction
        // Instead of trying to identify wall edges geometrically, we'll track the tab segments
        // and find the corresponding edges on the extracted surfaces
        
        // Track the tab segment edges themselves
        const trackedTabSegments = startTracking(context, tabSegmentEdges);
        
        println("Tab segment edges count (before extraction): " ~ toString(size(evaluateQuery(context, tabSegmentEdges))));

        try
        {
            @opExtractSurface(context, id + "extractWalls", {
                        "faces" : wallFaces,
                        "tangentPropagation" : false
                    });
            debug(context, wallFaces, DebugColor.BLUE);
        }
        catch
        {
            throw regenError("Failed to extract adjacent wall surfaces", ["edges"]);
        }

        // After extraction, find edges on extracted surfaces that are adjacent to the tracked tab segments
        const extractedBodies = qCreatedBy(id + "extractWalls", EntityType.BODY);
        const extractedEdges = qOwnedByBody(extractedBodies, EntityType.EDGE);
        
        // Find the tracked tab segments after extraction
        const trackedTabSegmentsAfterExtraction = qEntityFilter(trackedTabSegments, EntityType.EDGE);
        
        // Find edges on the extracted surfaces that share vertices with the tracked tab segments
        // These are the wall edges at the tab locations that we want to extend
        const edgesAdjacentToTrackedTabs = qIntersection([
            qAdjacent(trackedTabSegmentsAfterExtraction, AdjacencyType.VERTEX, EntityType.EDGE),
            extractedEdges
        ]);
        
        // Filter to only laminar (one-sided/boundary) edges to avoid EXTEND_NON_LAMINAR error
        const extractedEdgesToExtend = qEdgeTopologyFilter(edgesAdjacentToTrackedTabs, EdgeTopology.ONE_SIDED);
        
        println("Extracted edges count: " ~ toString(size(evaluateQuery(context, extractedEdges))));
        println("Tracked tab segments (after extraction): " ~ toString(size(evaluateQuery(context, trackedTabSegmentsAfterExtraction))));
        println("Edges adjacent to tracked tabs: " ~ toString(size(evaluateQuery(context, edgesAdjacentToTrackedTabs))));
        println("Laminar edges to extend count: " ~ toString(size(evaluateQuery(context, extractedEdgesToExtend))));
        
        if (size(evaluateQuery(context, extractedEdgesToExtend)) > 0)
        {
            try
            {
                @opExtendSheetBody(context, id + "extendTabs", {
                            "endCondition" : ExtendEndType.EXTEND_BLIND,
                            "entities" : extractedEdgesToExtend,
                            "tangentPropagation" : false,
                            "extendDistance" : definition.tabDepth,
                            "extensionShape" : ExtendSheetShapeType.LINEAR
                        });
                debug(context, extractedEdgesToExtend, DebugColor.GREEN);
            }
            catch
            {
                throw regenError("Failed to extend tab edges", ["tabDepth"]);
            }
        }
        else
        {
            println("Warning: No edges found to extend");
        }
    });

// Calculates split parameters for each edge within a path so a folded edge chain can be split into evenly sized segments.
// Adapted from custom-features/onlyTabs-refactor/splitSmEdgeChainToSegments.fs
// Inputs: path (ordered path representing the selected edge chain), segmentCount (desired number of segments for the chain).
// Outputs: Array of maps containing an edge query and the sorted parameters to split on that edge.
function calculateEdgeSplitInstructions(context is Context, path is Path, segmentCount is number) returns array
{
    const totalLength = evLength(context, {
                "entities" : qUnion(path.edges)
            });
    if (totalLength <= EDGE_LENGTH_TOLERANCE)
    {
        throw regenError("Selected edge chain must have a measurable length", ["edges"]);
    }

    var cumulativeFractions = [0];
    var accumulatedFraction = 0;
    for (var edgeIndex = 0; edgeIndex < size(path.edges); edgeIndex += 1)
    {
        const edge = path.edges[edgeIndex];
        const edgeLength = evLength(context, { "entities" : edge });
        if (edgeLength <= EDGE_LENGTH_TOLERANCE)
        {
            throw regenError("Edge chain contains a zero length edge", ["edges"], edge);
        }
        accumulatedFraction += edgeLength / totalLength;
        if (edgeIndex == size(path.edges) - 1)
        {
            accumulatedFraction = 1;
        }
        cumulativeFractions = append(cumulativeFractions, accumulatedFraction);
    }

    var fractionsToSplit = [];
    for (var index = 1; index < segmentCount; index += 1)
    {
        fractionsToSplit = append(fractionsToSplit, index / segmentCount);
    }

    var edgeParameterMap = {};
    var orderedEdgeIndices = [];
    for (var fraction in fractionsToSplit)
    {
        var assigned = false;
        for (var boundaryIndex = 1; boundaryIndex < size(cumulativeFractions); boundaryIndex += 1)
        {
            const startFraction = cumulativeFractions[boundaryIndex - 1];
            const endFraction = cumulativeFractions[boundaryIndex];
            if (fraction < startFraction - FRACTION_TOLERANCE)
            {
                continue;
            }
            if (fraction > endFraction + FRACTION_TOLERANCE)
            {
                continue;
            }

            const normalizedRange = endFraction - startFraction;
            if (normalizedRange <= EDGE_PARAMETER_TOLERANCE)
            {
                throw regenError("Edge chain contains a segment that cannot be subdivided", ["edges"], path.edges[boundaryIndex - 1]);
            }

            var edgeParameter = (fraction - startFraction) / normalizedRange;
            edgeParameter = max(0, min(1, edgeParameter));
            if (path.flipped[boundaryIndex - 1])
            {
                edgeParameter = 1 - edgeParameter;
            }

            if (edgeParameterMap[boundaryIndex - 1] == undefined)
            {
                edgeParameterMap[boundaryIndex - 1] = [];
                orderedEdgeIndices = append(orderedEdgeIndices, boundaryIndex - 1);
            }
            edgeParameterMap[boundaryIndex - 1] = append(edgeParameterMap[boundaryIndex - 1], edgeParameter);
            assigned = true;
            break;
        }

        if (!assigned)
        {
            const lastEdgeIndex = size(path.edges) - 1;
            var edgeParameter = path.flipped[lastEdgeIndex] ? EDGE_PARAMETER_TOLERANCE : 1 - EDGE_PARAMETER_TOLERANCE;
            if (edgeParameterMap[lastEdgeIndex] == undefined)
            {
                edgeParameterMap[lastEdgeIndex] = [];
                orderedEdgeIndices = append(orderedEdgeIndices, lastEdgeIndex);
            }
            edgeParameterMap[lastEdgeIndex] = append(edgeParameterMap[lastEdgeIndex], edgeParameter);
        }
    }

    var splitInstructions = [];
    for (var edgeIndex in orderedEdgeIndices)
    {
        var parameters = edgeParameterMap[edgeIndex];
        parameters = sort(parameters, function(a, b) { return a - b; });

        var filteredParameters = [];
        for (var parameter in parameters)
        {
            if (parameter <= EDGE_PARAMETER_TOLERANCE || parameter >= 1 - EDGE_PARAMETER_TOLERANCE)
            {
                continue;
            }
            if (size(filteredParameters) != 0 && abs(parameter - filteredParameters[size(filteredParameters) - 1]) < EDGE_PARAMETER_TOLERANCE)
            {
                continue;
            }
            filteredParameters = append(filteredParameters, parameter);
        }

        if (size(filteredParameters) == 0)
        {
            continue;
        }

        splitInstructions = append(splitInstructions, {
                    "edge" : path.edges[edgeIndex],
                    "parameters" : filteredParameters
                });
    }

    return splitInstructions;
}

// Filters a query of faces to return only those with SMObjectType.WALL attributes.
// Checks both direct attributes on faces and attributes on master definition entities.
// Inputs: faceQuery (query containing faces to filter).
// Outputs: Query containing only faces with wall attributes.
function filterSheetMetalWallFaces(context is Context, faceQuery is Query) returns Query
{
    const faces = evaluateQuery(context, faceQuery);
    var wallFaceQueries = [];
    
    for (var face in faces)
    {
        const faceAsQuery = qUnion([face]);
        
        // Check for direct attributes on the face
        var hasWallAttribute = hasSheetMetalAttribute(context, faceAsQuery, SMObjectType.WALL);
        
        // If no direct attribute, check master definition entities
        if (!hasWallAttribute)
        {
            const definitionEntities = getSMDefinitionEntities(context, faceAsQuery, EntityType.FACE);
            for (var defEntity in definitionEntities)
            {
                const defQuery = qUnion([defEntity]);
                if (hasSheetMetalAttribute(context, defQuery, SMObjectType.WALL))
                {
                    hasWallAttribute = true;
                    break;
                }
            }
        }
        
        if (hasWallAttribute)
        {
            wallFaceQueries = append(wallFaceQueries, faceAsQuery);
        }
    }
    
    if (size(wallFaceQueries) == 0)
    {
        return qNothing();
    }
    
    return qUnion(wallFaceQueries);
}

// Calculates tab domains for equal spacing distribution.
// Returns array of {start, end} maps with normalized parameters (0 to 1) for each tab location.
function calculateEqualSpacedTabDomains(totalLength is ValueWithUnits, tabWidth is ValueWithUnits, tabCount is number) returns array
{
    const tabWidthParam = tabWidth / totalLength;
    const spacing = (1 - (tabCount * tabWidthParam)) / (tabCount + 1);
    
    var tabDomains = [];
    for (var i = 0; i < tabCount; i += 1)
    {
        const start = spacing * (i + 1) + (tabWidthParam * i);
        const end = start + tabWidthParam;
        tabDomains = append(tabDomains, {"start" : start, "end" : end});
    }
    return tabDomains;
}

// Calculates tab domains for length-based spacing distribution.
// Returns array of {start, end} maps with normalized parameters (0 to 1) for each tab location.
function calculateLengthSpacedTabDomains(totalLength is ValueWithUnits, tabWidth is ValueWithUnits, spacing is ValueWithUnits, tabCount is number) returns array
{
    const tabWidthParam = tabWidth / totalLength;
    const spacingParam = spacing / totalLength;
    
    var tabDomains = [];
    var currentPos = spacingParam;  // Start after first gap
    
    for (var i = 0; i < tabCount; i += 1)
    {
        if (currentPos + tabWidthParam > 1)
        {
            break;  // Don't exceed the edge chain
        }
        tabDomains = append(tabDomains, {"start" : currentPos, "end" : currentPos + tabWidthParam});
        currentPos += tabWidthParam + spacingParam;
    }
    return tabDomains;
}

// Extracts all split parameters from tab domains.
// Returns sorted array of normalized parameters where splits should occur.
function calculateSplitParametersFromTabDomains(tabDomains is array) returns array
{
    var params = [];
    for (var domain in tabDomains)
    {
        params = append(params, domain.start);
        params = append(params, domain.end);
    }
    return params;
}

// Calculates split instructions from normalized parameters along the path.
// Similar to calculateEdgeSplitInstructions but uses explicit parameters instead of equal segments.
function calculateEdgeSplitInstructionsFromParameters(context is Context, path is Path, splitParameters is array) returns array
{
    const totalLength = evLength(context, {
                "entities" : qUnion(path.edges)
            });
    if (totalLength <= EDGE_LENGTH_TOLERANCE)
    {
        throw regenError("Selected edge chain must have a measurable length", ["edges"]);
    }

    var cumulativeFractions = [0];
    var accumulatedFraction = 0;
    for (var edgeIndex = 0; edgeIndex < size(path.edges); edgeIndex += 1)
    {
        const edge = path.edges[edgeIndex];
        const edgeLength = evLength(context, { "entities" : edge });
        if (edgeLength <= EDGE_LENGTH_TOLERANCE)
        {
            throw regenError("Edge chain contains a zero length edge", ["edges"], edge);
        }
        accumulatedFraction += edgeLength / totalLength;
        if (edgeIndex == size(path.edges) - 1)
        {
            accumulatedFraction = 1;
        }
        cumulativeFractions = append(cumulativeFractions, accumulatedFraction);
    }

    var edgeParameterMap = {};
    var orderedEdgeIndices = [];
    
    for (var fraction in splitParameters)
    {
        if (fraction <= FRACTION_TOLERANCE || fraction >= 1 - FRACTION_TOLERANCE)
        {
            continue;  // Skip parameters at or near endpoints
        }
        
        var assigned = false;
        for (var boundaryIndex = 1; boundaryIndex < size(cumulativeFractions); boundaryIndex += 1)
        {
            const startFraction = cumulativeFractions[boundaryIndex - 1];
            const endFraction = cumulativeFractions[boundaryIndex];
            
            if (fraction < startFraction - FRACTION_TOLERANCE)
            {
                continue;
            }
            if (fraction > endFraction + FRACTION_TOLERANCE)
            {
                continue;
            }

            const normalizedRange = endFraction - startFraction;
            if (normalizedRange <= EDGE_PARAMETER_TOLERANCE)
            {
                throw regenError("Edge chain contains a segment that cannot be subdivided", ["edges"], path.edges[boundaryIndex - 1]);
            }

            var edgeParameter = (fraction - startFraction) / normalizedRange;
            edgeParameter = max(0, min(1, edgeParameter));
            if (path.flipped[boundaryIndex - 1])
            {
                edgeParameter = 1 - edgeParameter;
            }

            if (edgeParameterMap[boundaryIndex - 1] == undefined)
            {
                edgeParameterMap[boundaryIndex - 1] = [];
                orderedEdgeIndices = append(orderedEdgeIndices, boundaryIndex - 1);
            }
            edgeParameterMap[boundaryIndex - 1] = append(edgeParameterMap[boundaryIndex - 1], edgeParameter);
            assigned = true;
            break;
        }
    }

    var splitInstructions = [];
    for (var edgeIndex in orderedEdgeIndices)
    {
        var parameters = edgeParameterMap[edgeIndex];
        parameters = sort(parameters, function(a, b) { return a - b; });

        var filteredParameters = [];
        for (var parameter in parameters)
        {
            if (parameter <= EDGE_PARAMETER_TOLERANCE || parameter >= 1 - EDGE_PARAMETER_TOLERANCE)
            {
                continue;
            }
            if (size(filteredParameters) != 0 && abs(parameter - filteredParameters[size(filteredParameters) - 1]) < EDGE_PARAMETER_TOLERANCE)
            {
                continue;
            }
            filteredParameters = append(filteredParameters, parameter);
        }

        if (size(filteredParameters) == 0)
        {
            continue;
        }

        splitInstructions = append(splitInstructions, {
                    "edge" : path.edges[edgeIndex],
                    "parameters" : filteredParameters
                });
    }

    return splitInstructions;
}

// Identifies edges that correspond to tab segments based on tab domains.
// Checks which edges fall within the tab domain ranges after splitting.
function identifyTabSegmentEdgesFromDomains(context is Context, splitEdges is Query, path is Path, totalLength is ValueWithUnits, tabDomains is array) returns Query
{
    if (size(tabDomains) == 0)
    {
        return qNothing();
    }

    const edges = evaluateQuery(context, splitEdges);
    if (size(edges) == 0)
    {
        return qNothing();
    }

    // Try to construct a path to get ordered edges
    const orderedPath = try silent(constructPath(context, qUnion(edges)));
    var orderedEdges = edges;
    if (orderedPath != undefined)
    {
        orderedEdges = orderedPath.edges;
    }

    // Calculate cumulative lengths to determine position of each edge
    var edgeMidpoints = [];
    var accumulatedLength = 0 * meter;
    
    for (var edge in orderedEdges)
    {
        const edgeLength = evLength(context, { "entities" : edge });
        const midpoint = (accumulatedLength + edgeLength / 2) / totalLength;
        edgeMidpoints = append(edgeMidpoints, midpoint);
        accumulatedLength += edgeLength;
    }

    // Identify which edges fall within tab domains
    var tabEdgeQueries = [];
    for (var i = 0; i < size(orderedEdges); i += 1)
    {
        const midpoint = edgeMidpoints[i];
        for (var domain in tabDomains)
        {
            if (midpoint >= domain.start && midpoint <= domain.end)
            {
                tabEdgeQueries = append(tabEdgeQueries, orderedEdges[i]);
                break;
            }
        }
    }

    if (size(tabEdgeQueries) == 0)
    {
        return qNothing();
    }

    return qUnion(tabEdgeQueries);
}

// Identifies wall edges that should be extended based on tab domains.
// Finds edges on wall faces that are perpendicular to the input edge chain and within tab positions.
// Inputs: wallEdges (all edges on wall faces), splitEdges (edges on input chain), path, totalLength, tabDomains
// Outputs: Query containing wall edges that should be extended at tab locations
function identifyWallEdgesToExtendFromDomains(context is Context, wallEdges is Query, splitEdges is Query, path is Path, totalLength is ValueWithUnits, tabDomains is array) returns Query
{
    if (size(tabDomains) == 0)
    {
        return qNothing();
    }

    const evaluatedWallEdges = evaluateQuery(context, wallEdges);
    if (size(evaluatedWallEdges) == 0)
    {
        return qNothing();
    }

    const evaluatedSplitEdges = evaluateQuery(context, splitEdges);
    
    // For each wall edge, check if it's positioned within a tab domain
    var edgesToExtendQueries = [];
    
    for (var wallEdge in evaluatedWallEdges)
    {
        // Check if this wall edge shares vertices with any split edge in a tab domain
        // Get vertices of the wall edge
        const wallEdgeVertices = qAdjacent(wallEdge, AdjacencyType.VERTEX, EntityType.VERTEX);
        
        // Check if any of these vertices are shared with tab segment edges
        const sharedWithSplitEdges = qIntersection([
            wallEdgeVertices,
            qAdjacent(splitEdges, AdjacencyType.VERTEX, EntityType.VERTEX)
        ]);
        
        if (size(evaluateQuery(context, sharedWithSplitEdges)) == 0)
        {
            continue;  // Wall edge doesn't touch the input edge chain
        }
        
        // Check if the wall edge is at a tab location by finding which split edge it shares vertices with
        const adjacentSplitEdges = qIntersection([
            qAdjacent(wallEdge, AdjacencyType.VERTEX, EntityType.EDGE),
            splitEdges
        ]);
        
        const evaluatedAdjacentSplitEdges = evaluateQuery(context, adjacentSplitEdges);
        
        // Check if any adjacent split edge is within tab domains
        for (var splitEdge in evaluatedAdjacentSplitEdges)
        {
            // Calculate the position of this split edge along the chain
            var edgePosition = calculateEdgePositionAlongPath(context, splitEdge, evaluatedSplitEdges, path, totalLength);
            
            // Check if this position falls within any tab domain
            for (var domain in tabDomains)
            {
                if (edgePosition >= domain.start && edgePosition <= domain.end)
                {
                    edgesToExtendQueries = append(edgesToExtendQueries, wallEdge);
                    break;
                }
            }
            
            if (size(edgesToExtendQueries) > 0 && edgesToExtendQueries[size(edgesToExtendQueries) - 1] == wallEdge)
            {
                break;  // Already added this wall edge
            }
        }
    }
    
    if (size(edgesToExtendQueries) == 0)
    {
        return qNothing();
    }
    
    return qUnion(edgesToExtendQueries);
}

// Helper function to calculate the midpoint position of an edge along the path
function calculateEdgePositionAlongPath(context is Context, edge is Query, orderedEdges is array, path is Path, totalLength is ValueWithUnits) returns number
{
    var accumulatedLength = 0 * meter;
    
    for (var orderedEdge in orderedEdges)
    {
        const edgeLength = evLength(context, { "entities" : orderedEdge });
        
        // Check if this is the edge we're looking for
        if (size(evaluateQuery(context, qIntersection([edge, orderedEdge]))) > 0)
        {
            return ((accumulatedLength + edgeLength / 2) / totalLength);
        }
        
        accumulatedLength += edgeLength;
    }
    
    return 0;  // Edge not found
}
