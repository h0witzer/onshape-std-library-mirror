export const SPACING_BOUNDS =
{
            (inch) : [1e-6, 6, 1e6]
        } as LengthBoundSpec;

export const TAB_WIDTH_BOUNDS =
{
            (inch) : [1e-6, 1, 1e6]
        } as LengthBoundSpec;

export const TAB_DEPTH_BOUNDS =
{
            (inch) : [1e-6, .05, 1e6]
        } as LengthBoundSpec;

export const SLOT_MARGIN_BOUNDS =
{
            (inch) : [0, .01, 1e6]
        } as LengthBoundSpec;
export const CHAMFER_WIDTH_BOUNDS =
{
            (inch) : [0, .02, 1]
        } as LengthBoundSpec;

export enum SpacingType
{
    annotation { "Name" : "Equal" }
    EQUAL,
    annotation { "Name" : "Length" }
    LENGTH
}

annotation { "Feature Type Name" : "OnlyTabs", "Feature Type Description" : "Tab and Slot feature for Sheet Metal", "Icon" : ICON::BLOB_DATA }
export const tabAndSlotBossDisplay = defineFeature(function(context is Context, id is Id, definition is map)
    precondition
    {
        // Define the parameters of the feature type
        annotation { "Name" : "Edges", "Filter" : EntityType.EDGE, "UIHint" : UIHint.SHOW_CREATE_SELECTION }
        definition.edges is Query;

        annotation { "Name" : "Spacing Type" }
        definition.spacingType is SpacingType;

        if (definition.spacingType == SpacingType.LENGTH)
        {
            annotation { "Name" : "Spacing" }
            isLength(definition.spacing, SPACING_BOUNDS);
        }

        if (definition.spacingType == SpacingType.EQUAL)
        {
            annotation { "Name" : "Tab Count" }
            isInteger(definition.tabCount, POSITIVE_COUNT_BOUNDS);
        }



        annotation { "Name" : "Tab Width" }
        isLength(definition.tabWidth, TAB_WIDTH_BOUNDS);

        annotation { "Name" : "Tab Depth" }
        isLength(definition.tabDepth, TAB_DEPTH_BOUNDS);

        annotation { "Name" : "Tab Chamfer Width" }
        isLength(definition.tabChamfer, CHAMFER_WIDTH_BOUNDS);

        annotation { "Name" : "Slot Width Margin" }
        isLength(definition.slotMargin, SLOT_MARGIN_BOUNDS);

        annotation { "Name" : "Merge Scope", "Filter" : EntityType.BODY }
        definition.mergeScope is Query;

        annotation { "Name" : "Remove Rip Joints" }
        definition.removeRipJoints is boolean;

    }
    {
        // Define locations of tabs on the tab part in 3d
        // Find the locations of the tabs on the slot part in 3d
        // Convert 3d points into flat 2d points
        // Create sketch on the face in the flat space
        // --- offset the edge shape
        // Add or remove the sketch

        if (definition.spacingType == SpacingType.EQUAL)
        {
            // Get length and calculate spacing
            var l = evLength(context, {
                    "entities" : definition.edges
                });

            definition.spacing = definition.tabWidth + ((l - ((definition.tabCount) * definition.tabWidth)) / (definition.tabCount + 1));

        }
        else if (definition.spacingType == SpacingType.LENGTH)
        {
            // Get length and calculate spacing
            var l = evLength(context, {
                    "entities" : definition.edges
                });



            definition.tabCount = floor((l - definition.tabWidth) / definition.spacing);
            println(definition.tabCount);
        }

        if(definition.removeRipJoints)
        {
            RemoveRips(context,definition);   
        }

        var tabPoints = GenerateTabParameters(context, id, definition);

        var tabPoints3D = GetSketchPositions3D(context, id, definition, tabPoints);
        debug(context, tabPoints3D, DebugColor.GREEN);

        var tablocations = GetSketchPositionsFlat(context, id, definition, tabPoints);
        debug(context, tabPoints3D, DebugColor.BLUE);
        definition.flatPlane = evPlane(context, {
                    "face" : tablocations.referenceFace
                });
        definition.referenceFace = tablocations.referenceFace;

        // TODO - generate tab shapes
        var tabSketches = GenerateTabSketches(context, id + "tabsketches", definition, tablocations.positions, true);

        // Join the Tabs
        debug(context, tabSketches, DebugColor.RED);
        extrude(context, id + ("tabs"), {
                    "domain" : OperationDomain.FLAT,
                    "flatOperationType" : FlatOperationType.ADD,
                    "entities" : tabSketches
                });
        if (!isQueryEmpty(context, definition.mergeScope))
        {
            var newFaces = qCreatedBy(id + "tabs", EntityType.FACE);
            var nonTabCapFaces = qAdjacent(definition.edges, AdjacencyType.VERTEX, EntityType.FACE);
            var tabCapFaces = qSubtraction(newFaces, nonTabCapFaces);
            //debug(context, tabCapFaces, DebugColor.GREEN);

            opThicken(context, id + "slotThickens", {
                        "entities" : tabCapFaces,
                        "thickness1" : 0.001 * inch, //I use a minimal amount of thicken here because boolean does the heavy lifting in sheet metal, this accidentally leads to the perfect amount of slot in the non-perpendicular case
                        "thickness2" : definition.tabDepth
                    });

            booleanBodies(context, id + "boolean1", {
                        "operationType" : BooleanOperationType.SUBTRACTION, // Subtract tools from the body
                        "tools" : qCreatedBy(id + "slotThickens", EntityType.BODY),
                        "targets" : definition.mergeScope,
                    });

            // add an offset?

            var createdFaces = qCreatedBy(id + "boolean1", EntityType.FACE);


            // but only the end faces?

            var endFaces = qSmallest(createdFaces);

            moveFace(context, id + "offsetfaces", {
                        "outputType" : MoveFaceOutputType.MOVE,
                        "moveFaces" : endFaces,
                        "surfacesAndFaces" : qUnion([]),
                        "moveFaceType" : MoveFaceType.OFFSET,
                        "direction" : qUnion([]),
                        "axis" : qUnion([]),
                        "limitType" : MoveFaceBoundingType.BLIND,
                        "translationDistance" : definition.slotMargin,
                        "angle" : 0 * degree,
                        "offsetDistance" : definition.slotMargin,
                        "oppositeDirection" : true,
                        "limitEntity" : qUnion([]),
                        "limitQuery" : qUnion([]),
                        "hasOffset" : false,
                        "offset" : 0 * inch,
                        "oppositeOffsetDirection" : true,
                        "reFillet" : true });


        }

        if (definition.tabChamfer > 0 * meter)
        {
            var edgesToChamfer = qNothing();
            var newEdges = qCreatedBy(id + "tabs", EntityType.EDGE);

            for (var e in evaluateQuery(context, newEdges))
            {
                var convexity = evEdgeConvexity(context, {
                        "edge" : e
                    });

                if (convexity == EdgeConvexityType.CONVEX)
                {
                    var inFlat = qCorrespondingInFlat(e);
                    if (!isQueryEmpty(context, qParallelEdges(inFlat, Z_DIRECTION)))
                    {

                        edgesToChamfer = qUnion(edgesToChamfer, e);
                    }
                }
            }

            sheetMetalCornerBreak(context, id + "cornerBreak", {
                        "blendType" : EdgeBlendType.CHAMFER,
                        "entities" : edgesToChamfer,
                        "chamferType" : ChamferType.EQUAL_OFFSETS,
                        "chamferMethod" : ChamferMethod.FACE_OFFSET,
                        "width" : definition.tabChamfer,
                        "oppositeDirection" : false,
                        "tangentPropagation" : false
                    });

        }

        var cleanup = qUnion([qCreatedBy(id + "tabsketches", EntityType.BODY), qCreatedBy(id + "slotSketches", EntityType.BODY)]);
        opDeleteBodies(context, id + "deleteBodies1", {
                    "entities" : cleanup
                });
    });

function RemoveRips(context is Context, definition is map)
{
    var adjFaces = qAdjacent(definition.edges, AdjacencyType.EDGE, EntityType.FACE);
    const smEntity = qUnion(getSMDefinitionEntities(context, adjFaces));
    var smEdge = qEntityFilter(smEntity, EntityType.EDGE);
    debug(context, smEdge, DebugColor.MAGENTA);
    
        for (var edge in evaluateQuery(context, smEdge))
        {
             var props = getSmObjectTypeAttributes(context, smEdge, SMObjectType.JOINT);
     
             if(size(props) > 0 && props[0].jointType.value == SMJointType.RIP)
             {
                 println("removing rip joint");
                  clearSmAttributes(context, edge);
             }
        }   
        
}

function GenerateTabSketches(context is Context, id is Id, definition is map, tablocations is array, isTabs is boolean) returns Query
{
    var resultQuery = qNothing();
    var edges = qOwnedByBody(qOwnerBody(definition.referenceFace), EntityType.EDGE);


    for (var i = 0; i < size(tablocations); i += 1)
    {
        var targetEdge = qClosestTo(edges, tablocations[i].origin);

        // determine if it is a straight edge

        var edgeType = evCurveDefinition(context, {
                "edge" : targetEdge
            });
        var tempPlane = definition.flatPlane;
        tempPlane.origin = tablocations[i].origin;
        tempPlane.x = isTabs ? -1 * tablocations[i].direction : tablocations[i].direction;
        if (edgeType is Line)
        {
            println(tempPlane);
            var sketch = newSketchOnPlane(context, id + ("sketch" ~ toString(i)), {
                    "sketchPlane" : tempPlane,
                    "planeReference" : definition.referenceFace
                });


            if (isTabs)
            {
                skRectangle(sketch, "rectangle1", {
                            "firstCorner" : vector(-definition.tabWidth / 2, 0 * inch),
                            "secondCorner" : vector(definition.tabWidth / 2, definition.tabDepth)
                        });
            }
            else
            {
                skRectangle(sketch, "rectangle1", {
                            "firstCorner" : vector(-(definition.tabWidth + definition.slotMargin) / 2, 0 * inch),
                            "secondCorner" : vector((definition.tabWidth + definition.slotMargin) / 2, definition.slotDepth)
                        });
            }



            skSolve(sketch);
            resultQuery = qUnion(resultQuery, qSketchRegion(id + ("sketch" ~ toString(i)), true));
        }
        else
        {

            // Get the parameters of start and edge of the tab width
            var edgeLength = evLength(context, {
                    "entities" : targetEdge
                });

            var midParameter = evDistance(context, {
                        "side0" : targetEdge,
                        "side1" : tablocations[i].origin
                    }).sides[0].parameter;

            var parameterizedWidth = (definition.tabWidth + (isTabs ? 0 * millimeter : definition.slotMargin * 2)) / edgeLength;

            var startParam = midParameter - (parameterizedWidth / 2);
            var endParam = midParameter + (parameterizedWidth / 2);
            // get the direction of the middle of the edge (that just the y direction given already)

            // sample points on the edge

            var parameterRange = range(startParam, endParam, 10); // 10 sample points?
            var samplePoints = evEdgeTangentLines(context, {
                    "edge" : targetEdge,
                    "parameters" : parameterRange
                });

            // offset and skfit spline
            var offsetEdgePoints = [];
            var onEdgePoints = [];
            for (var i = 0; i < size(samplePoints); i += 1)
            {
                if (isTabs)
                {
                    var onEdgePoint = worldToPlane(tempPlane, samplePoints[i].origin);
                    onEdgePoint[1] -= definition.tabDepth / 4; // just add a bit extra in case there are gaps
                    onEdgePoints = append(onEdgePoints, onEdgePoint);
                    var offsetPoint = worldToPlane(tempPlane, samplePoints[i].origin);
                    offsetPoint[1] += definition.tabDepth;
                    offsetEdgePoints = append(offsetEdgePoints, offsetPoint);
                }
                else
                {
                    var onEdgePoint = worldToPlane(tempPlane, samplePoints[i].origin);
                    onEdgePoint[1] += definition.slotDepth / 4; // just add a bit extra in case there are gaps
                    onEdgePoints = append(onEdgePoints, onEdgePoint);
                    var offsetPoint = worldToPlane(tempPlane, samplePoints[i].origin);
                    offsetPoint[1] -= definition.slotDepth;
                    offsetEdgePoints = append(offsetEdgePoints, offsetPoint);
                }


            }


            // generate connecting side edges
            var sketch = newSketchOnPlane(context, id + ("sketch" ~ toString(i)), {
                    "sketchPlane" : tempPlane,
                    "planeReference" : definition.referenceFace
                });

            skFitSpline(sketch, "onEdge", {
                        "points" : onEdgePoints
                    });
            skFitSpline(sketch, "offsetedge", {
                        "points" : offsetEdgePoints
                    });
            skLineSegment(sketch, "line1", {
                        "start" : onEdgePoints[0],
                        "end" : offsetEdgePoints[0]
                    });
            skLineSegment(sketch, "line2", {
                        "start" : onEdgePoints[size(onEdgePoints) - 1],
                        "end" : offsetEdgePoints[size(onEdgePoints) - 1]
                    });
            skSolve(sketch);
            resultQuery = qUnion(resultQuery, qSketchRegion(id + ("sketch" ~ toString(i)), true));

        }



    }
    return resultQuery;

}

function GetSketchPositions3D(context, id, definition, tabPoints is array) returns array
{
    var pathIn3D = constructPath(context, definition.edges);
    var edgeParams = PathToEdgeParams(context, pathIn3D, tabPoints);

    var sketchPositions = [];

    for (var i = 0; i < size(edgeParams); i += 1)
    {
        var tangent = evEdgeTangentLine(context, {
                "edge" : pathIn3D.edges[edgeParams[i].edgeIndex],
                "parameter" : edgeParams[i].parameter,
                "face" : qLargest(qAdjacent(pathIn3D.edges[edgeParams[i].edgeIndex], AdjacencyType.EDGE, EntityType.FACE))
            });

        var positionFlatNoFace = evEdgeTangentLine(context, {
                "edge" : pathIn3D.edges[edgeParams[i].edgeIndex],
                "parameter" : edgeParams[i].parameter
            });
  
        if (norm(tangent.origin - positionFlatNoFace.origin) > 1e-5 * meter)
        {
            tangent = evEdgeTangentLine(context, {
                        "edge" : pathIn3D.edges[edgeParams[i].edgeIndex],
                        "parameter" : 1.0 - edgeParams[i].parameter,
                        "face" : qLargest(qAdjacent(pathIn3D.edges[edgeParams[i].edgeIndex], AdjacencyType.EDGE, EntityType.FACE))
                    });
        }


        sketchPositions = append(sketchPositions, tangent);
    }

    return sketchPositions;
}

function GetSketchPositionsFlat(context, id, definition, tabPoints is array) returns map
{
    var flatPath = constructPath(context, qCorrespondingInFlat(definition.edges));
    var foldedPath = constructPath(context, definition.edges);
    var edgeParams = PathToEdgeParams(context, foldedPath, tabPoints);
    var flatAdjFaces = qAdjacent(qCorrespondingInFlat(definition.edges), AdjacencyType.EDGE, EntityType.FACE);
    //var referenceFace = qNthElement(qLargest(qParallelPlanes(qCorrespondingInFlat(qOwnedByBody(qOwnerBody(definition.edges), EntityType.FACE)), XY_PLANE, false)), 0);
    var referenceFace = qNthElement(qLargest(qParallelPlanes(flatAdjFaces, XY_PLANE, true)), 0);

    var tangentConnectedFaces = qTangentConnectedFaces(referenceFace);
    var sketchPositions = [];

    for (var i = 0; i < size(edgeParams); i += 1)
    {
        var tangent = evEdgeTangentLine(context, {
                "edge" : flatPath.edges[edgeParams[i].edgeIndex],
                "parameter" : edgeParams[i].parameter,
                "face" : qLargest(qAdjacent(flatPath.edges[edgeParams[i].edgeIndex], AdjacencyType.EDGE, EntityType.FACE))
            });

        var positionFlatNoFace = evEdgeTangentLine(context, {
                "edge" : flatPath.edges[edgeParams[i].edgeIndex],
                "parameter" : edgeParams[i].parameter
            });

        if (norm(tangent.origin - positionFlatNoFace.origin) > 1e-5 * meter)
        {
            tangent = evEdgeTangentLine(context, {
                        "edge" : flatPath.edges[edgeParams[i].edgeIndex],
                        "parameter" : 1.0 - edgeParams[i].parameter,
                        "face" : qLargest(qAdjacent(flatPath.edges[edgeParams[i].edgeIndex], AdjacencyType.EDGE, EntityType.FACE))
                    });
        }

        if (isQueryEmpty(context, qIntersection(tangentConnectedFaces, qLargest(qAdjacent(flatPath.edges[edgeParams[i].edgeIndex], AdjacencyType.EDGE, EntityType.FACE)))))
        {
            println("flip");
            tangent.direction = -1 * tangent.direction;
        }

        sketchPositions = append(sketchPositions, tangent);
    }

    return { "positions" : sketchPositions, "referenceFace" : referenceFace };
}


// Needed because oriented requires the edge parameter
function PathToEdgeParams(context is Context, p is Path, parameters is array) returns array
{
    var result = [];

    var pathLength = evLength(context, {
            "entities" : qUnion(p.edges)
        });

    var edgeLengths = [];
    var edgeParameterBoundaries = [0];
    var cur = 0;
    for (var edge in p.edges)
    {
        var edgeLength = evLength(context, {
                "entities" : edge
            });
        edgeLengths = append(edgeLengths, edgeLength);
        cur += edgeLength / pathLength;
        edgeParameterBoundaries = append(edgeParameterBoundaries, cur);
    }

    for (var i = 0; i < size(parameters); i += 1)
    {
        for (var j = 1; j < size(edgeParameterBoundaries); j += 1)
        {
            if (parameters[i] > edgeParameterBoundaries[j - 1] && parameters[i] < edgeParameterBoundaries[j])
            {
                // it is in this range
                var edgeParameterSize = edgeLengths[j - 1] / pathLength;
                var remaining = parameters[i] - edgeParameterBoundaries[j - 1];
                var edgeParam = remaining / edgeParameterSize;
                if (p.flipped[j - 1])
                {
                    edgeParam = 1.0 - edgeParam;
                }

                result = append(result, { "parameter" : edgeParam, "edgeIndex" : j - 1 });
                break;
            }
        }
    }

    return result;
}

function verticesInPath(context, edges) returns array
{
    var p = constructPath(context, edges);

    var pathLength = evLength(context, {
            "entities" : edges
        });

    var params = [0];
    var currentParamLength = 0;
    for (var i = 0; i < size(p.edges); i += 1)
    {
        var l = evLength(context, {
                "entities" : p.edges[i]
            });

        var portionOfPath = l / pathLength;
        currentParamLength += portionOfPath;
        params = append(params, currentParamLength);
    }
    return params;
}


function GenerateTabParameters(context, id, definition) returns array
{
    var edgesAsPath = constructPath(context, definition.edges);
    var pathLength = evLength(context, {
            "entities" : definition.edges
        });

    var flatlength = evLength(context, {
            "entities" : qCorrespondingInFlat(definition.edges)
        });


    // endpoints as path parameters?

    var parameterSpacing = definition.spacing / pathLength;
    var placementParams = [];
    for (var i = 0; i < definition.tabCount; i += 1)
    {
        var oddEvenParam = i % 2 == 0 ? 1 : -1;
        var newParam = 1.0;
        if (definition.tabCount % 2 == 0)
        {
            // even spacing offset from centre
            newParam = 0.5 + (oddEvenParam * parameterSpacing / 2) + (floor(i / 2) * parameterSpacing * oddEvenParam);
        }
        else if (i > 0)
        {
            // odd spacing starts at center
            newParam = 0.5 + (ceil(i / 2) * parameterSpacing * (i % 2 == 0 ? 1 : -1));
        }
        else
        {
            newParam = 0.5;
        }
        placementParams = append(placementParams, newParam);
    }

    // parameters should be shifted around to ensure no overlap with boundaries

    var tabWidthInParam = definition.tabWidth / pathLength;
    // determine if any tab is too close to an edge and shift it

    var pathVertices = verticesInPath(context, definition.edges);

    // gotta figure out where the edges even are in parameter space
    var finalParams = [];
    for (var i = 0; i < size(placementParams); i += 1)
    {
        var clear = true;
        for (var j = 0; j < size(pathVertices); j += 1)
        {
            if (placementParams[i] + tabWidthInParam / 2 > pathVertices[j] && placementParams[i] - tabWidthInParam / 2 < pathVertices[j])
            {
                clear = false;
            }
        }
        if (clear)
        {
            finalParams = append(finalParams, placementParams[i]);
        }
        else
        {
            // add a point to show a fail?
        }
    }

    return finalParams;

}
