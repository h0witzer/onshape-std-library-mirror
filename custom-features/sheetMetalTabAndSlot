// Filters a query of faces to return only those with SMObjectType.WALL attributes.
// Checks both direct attributes on faces and attributes on master definition entities.
// Inputs: faceQuery (query containing faces to filter).
// Outputs: Query containing only faces with wall attributes.
function filterSheetMetalWallFaces(context is Context, faceQuery is Query) returns Query
{
    const faces = evaluateQuery(context, faceQuery);
    var wallFaceQueries = [];
    
    for (var face in faces)
    {
        const faceAsQuery = qUnion([face]);
        
        // Check for direct attributes on the face
        var hasWallAttribute = hasSheetMetalAttribute(context, faceAsQuery, SMObjectType.WALL);
        
        // If no direct attribute, check master definition entities
        if (!hasWallAttribute)
        {
            const definitionEntities = getSMDefinitionEntities(context, faceAsQuery, EntityType.FACE);
            for (var defEntity in definitionEntities)
            {
                const defQuery = qUnion([defEntity]);
                if (hasSheetMetalAttribute(context, defQuery, SMObjectType.WALL))
                {
                    hasWallAttribute = true;
                    break;
                }
            }
        }
        
        if (hasWallAttribute)
        {
            wallFaceQueries = append(wallFaceQueries, faceAsQuery);
        }
    }
    
    if (size(wallFaceQueries) == 0)
    {
        return qNothing();
    }
    
    return qUnion(wallFaceQueries);
}

// Calculates tab domains for equal spacing distribution.
// Returns array of {start, end} maps with normalized parameters (0 to 1) for each tab location.
function calculateEqualSpacedTabDomains(totalLength is ValueWithUnits, tabWidth is ValueWithUnits, tabCount is number) returns array
{
    const tabWidthParam = tabWidth / totalLength;
    const spacing = (1 - (tabCount * tabWidthParam)) / (tabCount + 1);
    
    var tabDomains = [];
    for (var i = 0; i < tabCount; i += 1)
    {
        const start = spacing * (i + 1) + (tabWidthParam * i);
        const end = start + tabWidthParam;
        tabDomains = append(tabDomains, {"start" : start, "end" : end});
    }
    return tabDomains;
}

// Calculates tab domains for length-based spacing distribution.
// Returns array of {start, end} maps with normalized parameters (0 to 1) for each tab location.
function calculateLengthSpacedTabDomains(totalLength is ValueWithUnits, tabWidth is ValueWithUnits, spacing is ValueWithUnits, tabCount is number) returns array
{
    const tabWidthParam = tabWidth / totalLength;
    const spacingParam = spacing / totalLength;
    
    var tabDomains = [];
    var currentPos = spacingParam;  // Start after first gap
    
    for (var i = 0; i < tabCount; i += 1)
    {
        if (currentPos + tabWidthParam > 1)
        {
            break;  // Don't exceed the edge chain
        }
        tabDomains = append(tabDomains, {"start" : currentPos, "end" : currentPos + tabWidthParam});
        currentPos += tabWidthParam + spacingParam;
    }
    return tabDomains;
}

// Extracts all split parameters from tab domains.
// Returns sorted array of normalized parameters where splits should occur.
function calculateSplitParametersFromTabDomains(tabDomains is array) returns array
{
    var params = [];
    for (var domain in tabDomains)
    {
        params = append(params, domain.start);
        params = append(params, domain.end);
    }
    return params;
}

// Calculates split instructions from normalized parameters along the path.
// Similar to calculateEdgeSplitInstructions but uses explicit parameters instead of equal segments.
function calculateEdgeSplitInstructionsFromParameters(context is Context, path is Path, splitParameters is array) returns array
{
    const totalLength = evLength(context, {
                "entities" : qUnion(path.edges)
            });
    if (totalLength <= EDGE_LENGTH_TOLERANCE)
    {
        throw regenError("Selected edge chain must have a measurable length", ["edges"]);
    }

    var cumulativeFractions = [0];
    var accumulatedFraction = 0;
    for (var edgeIndex = 0; edgeIndex < size(path.edges); edgeIndex += 1)
    {
        const edge = path.edges[edgeIndex];
        const edgeLength = evLength(context, { "entities" : edge });
        if (edgeLength <= EDGE_LENGTH_TOLERANCE)
        {
            throw regenError("Edge chain contains a zero length edge", ["edges"], edge);
        }
        accumulatedFraction += edgeLength / totalLength;
        if (edgeIndex == size(path.edges) - 1)
        {
            accumulatedFraction = 1;
        }
        cumulativeFractions = append(cumulativeFractions, accumulatedFraction);
    }

    var edgeParameterMap = {};
    var orderedEdgeIndices = [];
    
    for (var fraction in splitParameters)
    {
        if (fraction <= FRACTION_TOLERANCE || fraction >= 1 - FRACTION_TOLERANCE)
        {
            continue;  // Skip parameters at or near endpoints
        }
        
        var assigned = false;
        for (var boundaryIndex = 1; boundaryIndex < size(cumulativeFractions); boundaryIndex += 1)
        {
            const startFraction = cumulativeFractions[boundaryIndex - 1];
            const endFraction = cumulativeFractions[boundaryIndex];
            
            if (fraction < startFraction - FRACTION_TOLERANCE)
            {
                continue;
            }
            if (fraction > endFraction + FRACTION_TOLERANCE)
            {
                continue;
            }

            const normalizedRange = endFraction - startFraction;
            if (normalizedRange <= EDGE_PARAMETER_TOLERANCE)
            {
                throw regenError("Edge chain contains a segment that cannot be subdivided", ["edges"], path.edges[boundaryIndex - 1]);
            }

            var edgeParameter = (fraction - startFraction) / normalizedRange;
            edgeParameter = max(0, min(1, edgeParameter));
            if (path.flipped[boundaryIndex - 1])
            {
                edgeParameter = 1 - edgeParameter;
            }

            if (edgeParameterMap[boundaryIndex - 1] == undefined)
            {
                edgeParameterMap[boundaryIndex - 1] = [];
                orderedEdgeIndices = append(orderedEdgeIndices, boundaryIndex - 1);
            }
            edgeParameterMap[boundaryIndex - 1] = append(edgeParameterMap[boundaryIndex - 1], edgeParameter);
            assigned = true;
            break;
        }
    }

    var splitInstructions = [];
    for (var edgeIndex in orderedEdgeIndices)
    {
        var parameters = edgeParameterMap[edgeIndex];
        parameters = sort(parameters, function(a, b) { return a - b; });

        var filteredParameters = [];
        for (var parameter in parameters)
        {
            if (parameter <= EDGE_PARAMETER_TOLERANCE || parameter >= 1 - EDGE_PARAMETER_TOLERANCE)
            {
                continue;
            }
            if (size(filteredParameters) != 0 && abs(parameter - filteredParameters[size(filteredParameters) - 1]) < EDGE_PARAMETER_TOLERANCE)
            {
                continue;
            }
            filteredParameters = append(filteredParameters, parameter);
        }

        if (size(filteredParameters) == 0)
        {
            continue;
        }

        splitInstructions = append(splitInstructions, {
                    "edge" : path.edges[edgeIndex],
                    "parameters" : filteredParameters
                });
    }

    return splitInstructions;
}

// Creates point entities at specified normalized parameters along a path.
// These points can be tracked through subsequent operations to identify edge segments.
// Inputs: 
//   - context: The current context
//   - id: The operation ID for creating points
//   - path: The edge chain path
//   - totalLength: Total length of the path
//   - normalizedParameters: Array of normalized parameters (0 to 1) where points should be created
// Outputs: Query containing the created point entities
function createTrackingPointsAlongPath(context is Context, id is Id, path is Path, totalLength is ValueWithUnits, normalizedParameters is array) returns Query
{
    if (size(normalizedParameters) == 0)
    {
        return qNothing();
    }
    
    // Calculate cumulative fractions for each edge in the path
    var cumulativeFractions = [0];
    var accumulatedFraction = 0;
    for (var edgeIndex = 0; edgeIndex < size(path.edges); edgeIndex += 1)
    {
        const edge = path.edges[edgeIndex];
        const edgeLength = evLength(context, { "entities" : edge });
        accumulatedFraction += edgeLength / totalLength;
        if (edgeIndex == size(path.edges) - 1)
        {
            accumulatedFraction = 1;
        }
        cumulativeFractions = append(cumulativeFractions, accumulatedFraction);
    }
    
    var pointQueries = [];
    var pointIndex = 0;
    
    for (var normalizedParam in normalizedParameters)
    {
        // Find which edge this parameter falls on
        for (var boundaryIndex = 1; boundaryIndex < size(cumulativeFractions); boundaryIndex += 1)
        {
            const startFraction = cumulativeFractions[boundaryIndex - 1];
            const endFraction = cumulativeFractions[boundaryIndex];
            
            if (normalizedParam < startFraction - FRACTION_TOLERANCE)
            {
                continue;
            }
            if (normalizedParam > endFraction + FRACTION_TOLERANCE)
            {
                continue;
            }
            
            // Calculate the parameter on this specific edge
            const normalizedRange = endFraction - startFraction;
            var edgeParameter = (normalizedParam - startFraction) / normalizedRange;
            edgeParameter = max(0, min(1, edgeParameter));
            
            if (path.flipped[boundaryIndex - 1])
            {
                edgeParameter = 1 - edgeParameter;
            }
            
            // Evaluate the point on the edge
            const tangentLine = evEdgeTangentLine(context, {
                        "edge" : path.edges[boundaryIndex - 1],
                        "parameter" : edgeParameter
                    });
            
            // Create a construction point at this location
            try
            {
                opPoint(context, id + ("point" ~ toString(pointIndex)), {
                            "point" : tangentLine.origin,
                            "origin" : tangentLine.origin
                        });
                pointQueries = append(pointQueries, qCreatedBy(id + ("point" ~ toString(pointIndex)), EntityType.VERTEX));
                pointIndex += 1;
            }
            catch
            {
                // If point creation fails, skip this point
            }
            break;
        }
    }
    
    if (size(pointQueries) == 0)
    {
        return qNothing();
    }
    
    return qUnion(pointQueries);
}

// Identifies tab segment edges by finding edges that contain the tracked tab center points.
// After splitting, each tab should be a single edge (or small set of edges) that contains
// one of the tracked center points.
// Inputs:
//   - context: The current context
//   - splitEdges: Query containing all edges after splitting
//   - trackedTabCenters: Query containing tracked points that represent tab centers
// Outputs: Query containing edges that are identified as tab segments
function identifyTabSegmentEdgesByTrackedPoints(context is Context, splitEdges is Query, trackedTabCenters is Query) returns Query
{
    const edges = evaluateQuery(context, splitEdges);
    const centerPoints = evaluateQuery(context, qEntityFilter(trackedTabCenters, EntityType.VERTEX));
    
    if (size(edges) == 0 || size(centerPoints) == 0)
    {
        return qNothing();
    }
    
    var tabEdgeQueries = [];
    
    // For each center point, find which edge it lies on
    for (var centerPoint in centerPoints)
    {
        const centerLocation = evVertexPoint(context, {
                    "vertex" : centerPoint
                });
        
        // Check each edge to see if it contains this point
        for (var edge in edges)
        {
            // Use distance to check if the point lies on the edge
            const distanceResult = evDistance(context, {
                        "side0" : centerLocation,
                        "side1" : edge
                    });
            
            // If the point is very close to the edge (within tolerance), this edge contains the tab center
            if (distanceResult.distance < EDGE_LENGTH_TOLERANCE)
            {
                tabEdgeQueries = append(tabEdgeQueries, edge);
                break;  // Found the edge for this center point, move to next point
            }
        }
    }
    
    if (size(tabEdgeQueries) == 0)
    {
        return qNothing();
    }
    
    return qUnion(tabEdgeQueries);
}

