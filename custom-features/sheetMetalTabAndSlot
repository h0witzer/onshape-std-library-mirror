/**
 * Merges the generated tab surface bodies with the sheet metal model.
 * 
 * Inputs:
 *   context - The evaluation context
 *   id - Operation ID for this merge operation
 *   tabSurfaceBodies - Query for the surface bodies to merge (created by extracting and extending wall faces)
 *   sourceWallFaces - The wall faces adjacent to tab segments (will be converted to definition entities by sheetMetalTab)
 *   definition - The feature definition containing merge scope (for slot subtraction) and slot margin parameters
 */
function mergeTabSurfacesWithSheetMetal(context is Context, id is Id, tabSurfaceBodies is Query, sourceWallFaces is Query, definition is map)
{
    // Get all faces from the tab surface bodies to pass as tabFaces
    const tabFaces = qOwnedByBody(tabSurfaceBodies, EntityType.FACE);
    
    const tabFaceCount = size(evaluateQuery(context, tabFaces));
    println("Preparing to merge " ~ toString(tabFaceCount) ~ " tab surface faces with sheet metal model");
    
    if (tabFaceCount == 0)
    {
        throw regenError("No tab surface faces found to merge. Check that edges were properly split and extended.", ["edges"]);
    }
    
    // Pass the source wall faces directly to booleanUnionScope
    // The sheetMetalTab feature will internally call getSMDefinitionEntities() on them
    // to extract the proper sheet metal definition entities
    const wallFaceCount = size(evaluateQuery(context, sourceWallFaces));
    
    if (wallFaceCount == 0)
    {
        throw regenError("No wall faces found to merge with", ["edges"]);
    }
    
    println("Source wall faces for merge: " ~ toString(wallFaceCount) ~ " faces");
    
    // mergeScope is for slot bodies (subtraction), not for the union operation
    // If mergeScope is provided, use it for booleanSubtractScope
    const subtractScope = !isQueryEmpty(context, definition.mergeScope) ? definition.mergeScope : qNothing();
    
    // Prepare data for sheet metal tab merge using ported logic from sheetMetalTabModified.fs
    // This replaces the call to modifiedSmTab::sheetMetalTab with inline implementation
    
    // NOTE: Unlike the original sheetMetalTabModified which calls createTools to extract surfaces,
    // we already have extracted and extended surface bodies (tabSurfaceBodies) from earlier operations.
    // So we skip the createTools call and use the existing bodies directly.
    
    const unionEntities = try silent(getSMDefinitionEntities(context, sourceWallFaces));
    if (unionEntities == undefined || unionEntities == [])
    {
        throw regenError(ErrorStringEnum.SHEET_METAL_TAB_NO_WALL, ["edges"]);
    }
    const unionEntityQuery = qUnion(unionEntities);
    const unionBodies = evaluateQuery(context, qOwnerBody(unionEntityQuery));

    if (isAtVersionOrLater(context, FeatureScriptVersionNumber.V1235_TAB_MERGE_AND_SUBTRACT))
    {
        const subtractEntityQuery = qUnion(getSMDefinitionEntities(context, subtractScope));
        const entitiesInBothUnionAndSubtract = evaluateQuery(context, qIntersection([unionEntityQuery, subtractEntityQuery]));
        if (entitiesInBothUnionAndSubtract != [])
        {
            throw regenError(ErrorStringEnum.SHEET_METAL_TAB_MERGE_AND_SUBTRACT_SAME_FLANGE, ["mergeScope"], qUnion(entitiesInBothUnionAndSubtract));
        }
    }

    var subtractBodies = getOwnerSMModel(context, subtractScope);
    var sheetMetalBodiesQuery = qUnion(concatenateArrays([subtractBodies, unionBodies]));
    const initialData = getInitialEntitiesAndAttributes(context, sheetMetalBodiesQuery);
    sheetMetalBodiesQuery = qUnion([startTracking(context, sheetMetalBodiesQuery), sheetMetalBodiesQuery]);

    const unionEntityPersistantQuery = qUnion([unionEntityQuery, startTracking(context, unionEntityQuery)]);
    const associateChanges = startTracking(context, qOwnedByBody(sheetMetalBodiesQuery, EntityType.FACE));

    const selectionsByModelId = partitionSheetMetalQueriesByModel(context, unionEntities);
    var index = 0;
    var oneSuccess = false;
    
    // Build definition for applyTab that matches what sheetMetalTab expects
    // We need booleanOffset and booleanSubtractScope fields
    const tabMergeDefinition = {
        "booleanOffset" : definition.slotMargin,
        "booleanSubtractScope" : subtractScope
    };
    
    for (var pair in selectionsByModelId)
    {
        // Use tabFaces directly - these are already the extracted/extended surface faces
        oneSuccess = applyTab(context, id + unstableIdComponent(index), tabMergeDefinition, tabFaces, pair.value, id) || oneSuccess;
        index += 1;
    }

    if (!oneSuccess)
    {
        throw regenError("Tab merge had no effect", ["edges"]);
    }

    // Don't delete the tab surface bodies - they get consumed by the boolean operations in applyTab

    const toUpdate = assignSMAttributesToNewOrSplitEntities(context, sheetMetalBodiesQuery, initialData, id);

    updateSheetMetalGeometry(context, id, {
                "entities" : qUnion([toUpdate.modifiedEntities, unionEntityPersistantQuery]),
                "deletedAttributes" : toUpdate.deletedAttributes,
                "associatedChanges" : associateChanges });
    
    println("Successfully merged tab surfaces with sheet metal model");
}
